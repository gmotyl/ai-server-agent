# config/agent.conf.example
# Copy to agent.conf and fill in your values

# --- Telegram ---
TELEGRAM_BOT_TOKEN=""
TELEGRAM_GROUP_ID=""

# --- Heartbeat ---
HEARTBEAT_INTERVAL_MIN=30
HEARTBEAT_TIMEOUT_SEC=3600

# --- Default AI Provider ---
DEFAULT_PROVIDER="claude"

# --- Provider Commands ---
# {prompt_file} = path to temp file containing the prompt (safe, no injection)
# {workdir} = working directory inside the container
#
# Docker (for server deployment):
# NOTE: prompt is passed via stdin (-i) so no bind mount needed.
# The temp file stays mode 600 (owner-only); Docker reads it through the pipe.
PROVIDER_CMD_claude="docker compose -f \${AGENT_HOME}/docker/docker-compose.yml run --rm -i -w {workdir} claude sh -c 'claude --dangerously-skip-permissions -p \"\$(cat)\"' < {prompt_file}"
PROVIDER_CMD_gemini="docker compose -f \${AGENT_HOME}/docker/docker-compose.yml run --rm -i -w {workdir} gemini sh -c 'gemini -p \"\$(cat)\"' < {prompt_file}"
PROVIDER_CMD_codex="docker compose -f \${AGENT_HOME}/docker/docker-compose.yml run --rm -i -w {workdir} codex sh -c 'codex --auto-approve -p \"\$(cat)\"' < {prompt_file}"
#
# Local (for testing without Docker — runs CLI directly on host):
# PROVIDER_CMD_claude='cd {workdir} && claude --dangerously-skip-permissions -p "$(cat {prompt_file})"'
# PROVIDER_CMD_gemini='cd {workdir} && gemini -p "$(cat {prompt_file})"'

# --- Paths ---
# AGENT_HOME is auto-detected from install location, override if needed
# AGENT_HOME="/share/CACHEDEV1_DATA/ai-server-agent"
# GIT_DIR defaults to ${AGENT_HOME}/git
# GIT_DIR="/share/CACHEDEV1_DATA/ai-server-agent/git"

# --- Telegram Message Limits ---
MAX_MESSAGE_LENGTH=4096
