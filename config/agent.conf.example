# config/agent.conf.example
# Copy to agent.conf and fill in your values

# --- Telegram ---
TELEGRAM_BOT_TOKEN=""
TELEGRAM_GROUP_ID=""

# --- Heartbeat ---
HEARTBEAT_INTERVAL_MIN=30
HEARTBEAT_TIMEOUT_SEC=3600
# How long to wait for a Telegram message before looping (seconds).
# Higher = less disk activity on NAS. Max ~55 (Telegram API limit).
POLL_TIMEOUT=55

# --- Default AI Provider ---
DEFAULT_PROVIDER="claude"

# --- Provider Commands ---
# {prompt_file} = path to temp file containing the prompt (safe, no injection)
# {workdir} = working directory inside the container
#
# Docker (for server deployment):
# NOTE: prompt is passed via stdin (-i) so no bind mount needed.
# The temp file stays mode 600 (owner-only); Docker reads it through the pipe.
# NOTE: Do NOT use -w {workdir} — let docker-compose.yml's working_dir take effect.
# NOTE: chmod -R a+rw /memory/ restores write access after Docker (which may run as root)
#       writes files that the host user (non-root) would otherwise be unable to modify.
PROVIDER_CMD_claude="docker compose -f \${AGENT_HOME}/docker/docker-compose.yml run --rm -i claude sh -c 'claude --dangerously-skip-permissions -p \"\$(cat)\" ; chmod -R a+rw /memory/ 2>/dev/null' < {prompt_file}"
PROVIDER_CMD_gemini="docker compose -f \${AGENT_HOME}/docker/docker-compose.yml run --rm -i gemini sh -c 'gemini -p \"\$(cat)\" ; chmod -R a+rw /memory/ 2>/dev/null' < {prompt_file}"
PROVIDER_CMD_codex="docker compose -f \${AGENT_HOME}/docker/docker-compose.yml run --rm -i codex sh -c 'codex --auto-approve -p \"\$(cat)\" ; chmod -R a+rw /memory/ 2>/dev/null' < {prompt_file}"
#
# Local (for testing without Docker — runs CLI directly on host):
# PROVIDER_CMD_claude='cd {workdir} && claude --dangerously-skip-permissions -p "$(cat {prompt_file})"'
# PROVIDER_CMD_gemini='cd {workdir} && gemini -p "$(cat {prompt_file})"'

# --- Paths ---
# IMPORTANT: use 'export' so these are visible to provider subprocesses
# AGENT_HOME is auto-detected from install location, override if needed
# export AGENT_HOME="/share/CACHEDEV1_DATA/ai-server-agent"
# GIT_DIR defaults to ${AGENT_HOME}/git
# export GIT_DIR="/share/CACHEDEV1_DATA/ai-server-agent/git"

# --- Telegram Message Limits ---
MAX_MESSAGE_LENGTH=4096
