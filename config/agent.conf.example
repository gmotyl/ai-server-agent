# config/agent.conf.example
# Copy to agent.conf and fill in your values

# --- Telegram ---
TELEGRAM_BOT_TOKEN=""
TELEGRAM_GROUP_ID=""

# --- Heartbeat ---
HEARTBEAT_INTERVAL_MIN=30
HEARTBEAT_TIMEOUT_SEC=3600

# --- Default AI Provider ---
DEFAULT_PROVIDER="claude"

# --- Provider Commands ---
# {prompt_file} = path to temp file containing the prompt (safe, no injection)
# {workdir} = working directory inside the container
#
# Docker (for server deployment):
PROVIDER_CMD_claude='docker compose -f ${AGENT_HOME}/docker/docker-compose.yml run --rm -v {prompt_file}:/tmp/prompt:ro -w {workdir} claude claude --dangerously-skip-permissions -p "$(cat /tmp/prompt)"'
PROVIDER_CMD_gemini='docker compose -f ${AGENT_HOME}/docker/docker-compose.yml run --rm -v {prompt_file}:/tmp/prompt:ro -w {workdir} gemini gemini -p "$(cat /tmp/prompt)"'
PROVIDER_CMD_codex='docker compose -f ${AGENT_HOME}/docker/docker-compose.yml run --rm -v {prompt_file}:/tmp/prompt:ro -w {workdir} codex codex --auto-approve -p "$(cat /tmp/prompt)"'
#
# Local (for testing without Docker — runs CLI directly on host):
# PROVIDER_CMD_claude='cd {workdir} && claude --dangerously-skip-permissions -p "$(cat {prompt_file})"'
# PROVIDER_CMD_gemini='cd {workdir} && gemini -p "$(cat {prompt_file})"'

# --- Paths ---
# IMPORTANT: use 'export' so these are visible to provider subprocesses
# AGENT_HOME is auto-detected from install location, override if needed
# export AGENT_HOME="/share/CACHEDEV1_DATA/ai-server-agent"
# GIT_DIR defaults to ${AGENT_HOME}/git
# export GIT_DIR="/share/CACHEDEV1_DATA/ai-server-agent/git"

# --- Telegram Message Limits ---
MAX_MESSAGE_LENGTH=4096
