#!/usr/bin/env python3
"""
review-doc — publish a markdown document as a temp HTML page for review.

Usage:
  review-doc <title> <markdown_file>
  echo "# Doc" | review-doc <title>
  review-doc --list        show active docs
  review-doc --expire      remove docs older than TTL_HOURS

Reads NAS_HOST env var (default: localhost) for the URL shown to user.
"""

import sys
import os
import re
import hashlib
import time
import json
import argparse
import signal
import subprocess
import textwrap
from pathlib import Path
from datetime import datetime, timezone

# Config
DOCS_DIR = Path("/git/ai-server-agent/data/review-docs")
PORT = 8099
TTL_HOURS = int(os.environ.get("REVIEW_DOC_TTL", "24"))
NAS_HOST = os.environ.get("NAS_HOST", "nas")
SERVER_PID_FILE = DOCS_DIR / ".server.pid"
INDEX_FILE = DOCS_DIR / "index.json"

HTML_TEMPLATE = """\
<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{title}</title>
<style>
  * {{ box-sizing: border-box; margin: 0; padding: 0; }}
  body {{
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 16px;
    line-height: 1.7;
    color: #1a1a1a;
    background: #f8f8f6;
    padding: 2rem 1rem;
  }}
  .container {{
    max-width: 820px;
    margin: 0 auto;
    background: #fff;
    border-radius: 8px;
    box-shadow: 0 2px 12px rgba(0,0,0,.08);
    padding: 2.5rem 3rem;
  }}
  .meta {{
    font-size: .85rem;
    color: #888;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid #eee;
  }}
  h1 {{ font-size: 1.9rem; margin-bottom: .4rem; color: #111; }}
  h2 {{
    font-size: 1.35rem;
