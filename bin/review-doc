  strong {{ font-weight: 600; }}
  em {{ font-style: italic; color: #555; }}
  a {{ color: #2563eb; text-decoration: none; }}
  a:hover {{ text-decoration: underline; }}
  .toc {{
    background: #f8f8f6;
