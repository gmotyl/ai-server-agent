    <div class="toc-title">Spis treści</div>
    <ul>{toc_items}</ul>
  </nav>
  {body}
</div>
</body>
</html>
"""


def markdown_to_html(md: str) -> tuple[str, list[tuple[str, str, str]]]:
    """Convert simple markdown to HTML and return (html, toc_entries).
    toc_entries: list of (level, anchor, label_with_number)
    Numbers h2 and h3 sections automatically.
    """
    lines = md.split("\n")
    html_parts = []
    toc = []
    h2_counter = 0
    h3_counter = 0
    in_code_block = False
    code_lang = ""
    code_lines = []
    in_list = False
    list_ordered = False

    def flush_list():
        nonlocal in_list, list_ordered
        if not in_list:
            return ""
        tag = "ol" if list_ordered else "ul"
        in_list = False
        return f"</{tag}>\n"

    def process_inline(text: str) -> str:
        # bold
        text = re.sub(r"\*\*(.+?)\*\*", r"<strong>\1</strong>", text)
        text = re.sub(r"__(.+?)__", r"<strong>\1</strong>", text)
        # italic
        text = re.sub(r"\*(.+?)\*", r"<em>\1</em>", text)
        text = re.sub(r"_(.+?)_", r"<em>\1</em>", text)
        # inline code
        text = re.sub(r"`(.+?)`", r"<code>\1</code>", text)
        # links
        text = re.sub(r"\[(.+?)\]\((.+?)\)", r'<a href="\2">\1</a>', text)
        return text

    for line in lines:
        # Code blocks
        if line.startswith("```"):
            if in_code_block:
                html_parts.append(flush_list())
                html_parts.append(f"<pre><code>{chr(10).join(code_lines)}</code></pre>")
                code_lines = []
                in_code_block = False
            else:
                html_parts.append(flush_list())
                code_lang = line[3:].strip()
                in_code_block = True
            continue

        if in_code_block:
            code_lines.append(line.replace("&", "&amp;").replace("<", "&lt;").replace(">", "&gt;"))
            continue

        # HR
        if re.match(r"^[-*_]{3,}$", line.strip()):
            html_parts.append(flush_list())
            html_parts.append("<hr>")
            continue

        # Headings
        m = re.match(r"^(#{1,6})\s+(.*)", line)
        if m:
            html_parts.append(flush_list())
            level = len(m.group(1))
            raw_text = m.group(2).strip()
            anchor = re.sub(r"[^\w\s-]", "", raw_text.lower()).strip().replace(" ", "-")

            if level == 2:
                h2_counter += 1
                h3_counter = 0
                num = str(h2_counter)
                badge = f'<span class="sec-num">{num}</span>'
                anchor = f"s{num}"
                label = f"{num}. {raw_text}"
                html_parts.append(f'<h2 id="{anchor}">{badge}{process_inline(raw_text)}</h2>')
                toc.append(("h2", anchor, label))
            elif level == 3:
                h3_counter += 1
                num = f"{h2_counter}.{h3_counter}"
                badge = f'<span class="sec-num">{num}</span>'
                anchor = f"s{num.replace('.', '-')}"
                label = f"{num} {raw_text}"
                html_parts.append(f'<h3 id="{anchor}">{badge}{process_inline(raw_text)}</h3>')
                toc.append(("h3", anchor, label))
            elif level == 1:
                html_parts.append(f'<h1 id="{anchor}">{process_inline(raw_text)}</h1>')
            else:
                html_parts.append(f'<h{level} id="{anchor}">{process_inline(raw_text)}</h{level}>')
            continue

        # Blockquote
        if line.startswith("> "):
            html_parts.append(flush_list())
            html_parts.append(f"<blockquote><p>{process_inline(line[2:])}</p></blockquote>")
            continue

        # Unordered list
        m = re.match(r"^[-*+]\s+(.*)", line)
        if m:
            if not in_list or list_ordered:
                html_parts.append(flush_list())
                html_parts.append("<ul>")
                in_list = True
                list_ordered = False
            html_parts.append(f"<li>{process_inline(m.group(1))}</li>")
            continue

        # Ordered list
        m = re.match(r"^\d+\.\s+(.*)", line)
        if m:
            if not in_list or not list_ordered:
                html_parts.append(flush_list())
                html_parts.append("<ol>")
                in_list = True
                list_ordered = True
            html_parts.append(f"<li>{process_inline(m.group(1))}</li>")
            continue

        # Empty line
        if not line.strip():
            html_parts.append(flush_list())
            html_parts.append("")
            continue

        # Paragraph
        html_parts.append(flush_list())
        html_parts.append(f"<p>{process_inline(line)}</p>")

    html_parts.append(flush_list())
    return "\n".join(html_parts), toc


def ensure_server_running():
    """Start Python HTTP server if not already running."""
    if SERVER_PID_FILE.exists():
        pid = int(SERVER_PID_FILE.read_text().strip())
        try:
            os.kill(pid, 0)  # check if alive
            return  # already running
        except ProcessLookupError:
            SERVER_PID_FILE.unlink(missing_ok=True)

    proc = subprocess.Popen(
        [sys.executable, "-m", "http.server", str(PORT), "--directory", str(DOCS_DIR)],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        start_new_session=True,
    )
    SERVER_PID_FILE.write_text(str(proc.pid))


def load_index() -> dict:
    if INDEX_FILE.exists():
        return json.loads(INDEX_FILE.read_text())
    return {}


def save_index(data: dict):
    INDEX_FILE.write_text(json.dumps(data, indent=2, ensure_ascii=False))


def telegram_send_document(topic_id: str, file_path: Path, caption: str = "") -> bool:
    """Send a file as a Telegram document. Returns True on success."""
    bot_token = os.environ.get("TELEGRAM_BOT_TOKEN", "")
    group_id = os.environ.get("TELEGRAM_GROUP_ID", "")
    if not bot_token or not group_id:
        return False
    cmd = [
        "curl", "-s",
        f"https://api.telegram.org/bot{bot_token}/sendDocument",
        "-F", f"chat_id={group_id}",
        "-F", f"message_thread_id={topic_id}",
        "-F", f"document=@{file_path}",
    ]
    if caption:
        cmd += ["-F", f"caption={caption}"]
    result = subprocess.run(cmd, capture_output=True, text=True)
    try:
        data = json.loads(result.stdout)
        return data.get("ok", False)
    except Exception:
        return False


def generate_pdf(html_path: Path) -> Path | None:
    """Convert HTML to PDF using wkhtmltopdf. Returns PDF path or None."""
    wk = subprocess.run(["which", "wkhtmltopdf"], capture_output=True, text=True)
    if wk.returncode != 0:
        return None
    pdf_path = html_path.with_suffix(".pdf")
    r = subprocess.run(
        ["wkhtmltopdf", "--quiet", str(html_path), str(pdf_path)],
        capture_output=True,
    )
    return pdf_path if r.returncode == 0 and pdf_path.exists() else None


def cmd_publish(title: str, md_text: str, send_topic: str | None = None, send_pdf: bool = False):
    DOCS_DIR.mkdir(parents=True, exist_ok=True)

    doc_id = hashlib.md5(f"{title}{time.time()}".encode()).hexdigest()[:8]
    filename = f"{doc_id}.html"

    now = datetime.now(timezone.utc)
    expires = datetime.fromtimestamp(time.time() + TTL_HOURS * 3600, tz=timezone.utc)
    gen_str = now.strftime("%Y-%m-%d %H:%M UTC")
    exp_str = expires.strftime("%Y-%m-%d %H:%M UTC")

    body_html, toc = markdown_to_html(md_text)

    toc_items = ""
    for level, anchor, label in toc:
        indent = "  " if level == "h3" else ""
        toc_items += f'\n    {indent}<li><a href="#{anchor}">{label}</a></li>'

    html = HTML_TEMPLATE.format(
        title=title,
        generated_at=gen_str,
        expires_at=exp_str,
        toc_items=toc_items,
        body=body_html,
    )

    out_path = DOCS_DIR / filename
    out_path.write_text(html, encoding="utf-8")

    # Update index
    index = load_index()
    index[doc_id] = {
        "title": title,
        "file": filename,
        "created": now.isoformat(),
        "expires": expires.isoformat(),
    }
    save_index(index)

    ensure_server_running()

    url = f"http://{NAS_HOST}:8099/{filename}"
    print(url)
    print(f"FILE:{out_path}")

    if send_topic:
        if send_pdf:
            pdf_path = generate_pdf(out_path)
            if pdf_path:
                ok = telegram_send_document(send_topic, pdf_path, caption=f"📄 {title}")
                print(f"PDF:{'sent' if ok else 'failed'}")
            else:
                print("PDF:wkhtmltopdf not available — falling back to HTML")
                ok = telegram_send_document(send_topic, out_path, caption=f"📄 {title} (HTML)")
                print(f"HTML:{'sent' if ok else 'failed'}")
        else:
            ok = telegram_send_document(send_topic, out_path, caption=f"📄 {title}")
            print(f"HTML:{'sent' if ok else 'failed'}")


def cmd_list():
    index = load_index()
    if not index:
        print("Brak aktywnych dokumentów.")
        return
    now = datetime.now(timezone.utc)
    for doc_id, meta in index.items():
        exp = datetime.fromisoformat(meta["expires"])
        status = "aktywny" if exp > now else "WYGASŁ"
        print(f"[{doc_id}] {meta['title']} — {status} (wygasa {meta['expires'][:16]})")


def cmd_expire():
    index = load_index()
    now = datetime.now(timezone.utc)
    removed = 0
    for doc_id in list(index.keys()):
        exp = datetime.fromisoformat(index[doc_id]["expires"])
        if exp <= now:
            f = DOCS_DIR / index[doc_id]["file"]
            f.unlink(missing_ok=True)
            del index[doc_id]
            removed += 1
    save_index(index)
    print(f"Usunięto {removed} wygasłych dokumentów.")


def main():
    parser = argparse.ArgumentParser(description="Publish markdown doc as temp HTML review page")
    parser.add_argument("--list", action="store_true", help="List active docs")
    parser.add_argument("--expire", action="store_true", help="Remove expired docs")
    parser.add_argument("--send", metavar="TOPIC_ID", help="Send file as Telegram document to topic")
    parser.add_argument("--pdf", action="store_true", help="Send as PDF instead of HTML (requires wkhtmltopdf)")
    parser.add_argument("title", nargs="?", help="Document title")
    parser.add_argument("file", nargs="?", help="Markdown file (or omit to read stdin)")
    args = parser.parse_args()

    if args.list:
        cmd_list()
        return
    if args.expire:
        cmd_expire()
        return

    if not args.title:
        parser.print_help()
        sys.exit(1)

    if args.file:
        md_text = Path(args.file).read_text(encoding="utf-8")
    else:
        md_text = sys.stdin.read()

    cmd_publish(args.title, md_text, send_topic=args.send, send_pdf=args.pdf)


if __name__ == "__main__":
    main()
